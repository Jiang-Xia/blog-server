app_desc =

# Database
db_type = mysql
db_host = 127.0.0.1
db_port = 3306
db_username =
db_password =
db_database = myblog
db_synchronize = false
db_logging = 'error'

# Redis
redis_host = 127.0.0.1
redis_port = 6379
redis_db = 1

# Server
serve_port = 5000
serve_apiPath = api/v1
serve_baseUrl = http://127.0.0.1:5000

# CORS (comma-separated origins; empty means dev allows all)
serve_corsOrigins =

# Auth (JWT)
auth_jwtSecret =

# Default admin account (first-run init)
account_mobile =
account_password =
account_role =
account_nickname =
account_passwordRepeat =

# File uploads
file_filePath = ./public/uploads/

# Logging
app_openMsgLog = false
app_closeMsgBodyLog = true

# Optional: AES gateway encryption (keep consistent with client)
app_aesKey =
app_aesIv =

# Optional: third-party integrations
app_gaoDeMapApiKey =
app_emailHost =
app_emailPort =
app_emailUser =
app_emailPass =
app_blogHome =
app_githubClientId =
app_githubClientSecret =
app_githubCallbackUrl =

# Pay
pay_alipayAppId =
pay_alipayPrivateKey =
pay_alipayPublicKey =
pay_alipayGateway = https://openapi.alipay.com/gateway.do
pay_alipaySignType = RSA2
pay_alipayTimeout = 5000
pay_alipayNotifyUrl =
pay_alipayReturnUrl =
pay_wechatAppId =
pay_wechatSecret =
